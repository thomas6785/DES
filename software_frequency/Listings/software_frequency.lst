                     194     
  00B6               195     SOUND           EQU     P3.6            ; P3.4 is red LED on eval board 
                     196     ;____________________________________________________________________
                     197                     ; MAIN PROGRAM
----                 198     CSEG            ; working in code segment - program memory
                     199     
0000                 200                     ORG     0000h                   ; starting at address 0
0000                 201     MAIN:
0000                 202     LOOP:
0000 1106            203                     CALL  DELAY                     ; call software delay routine           (3 
                             cycles for jump + see subroutine)
0002 B2B6            204                     CPL   SOUND                     ; flip the output bit 'SOUND'           (2 
                             cycles)
0004 80FA            205                     JMP   LOOP                      ; return to loop start                     
                                  (3 cycles)
                     206                     ; NOTE: next address is 0003h which is reserved for interrupts. If we need 
                             more setup instructions, we'll have to put in a jump to MAIN elsewhere
                     207                     ; Loop is 6144 clocks total giving precisely 900 Hz wave at 11.0592 MHz
                     208     
                     209     ;____________________________________________________________________
                     210                     ; SUBROUTINES
0006                 211     DELAY:  ; Delay for using two nested FOR loops
                     212                     ; Delay is 6139 clocks including CALL and RET
                     213                     ; R5 and R7 are changed
0006 7D10            214                     MOV     R5, #16                 ; set outer loop to 16 repetitions      (2 
                             cycles)
0008 7F7E            215     DLY1:   MOV     R7, #126                ; set inner loop to 126 repetitions     (2 cycles *
                              16)
000A DFFE            216                     DJNZ    R7, $           ; DJNZ inner loop                                  
                                  (3 cycles * 126 * 16)
000C DDFA            217                     DJNZ    R5, DLY1        ; DJNZ outer loop                                  
                                  (3 cycles * 16)
000E 00              218                     NOP                             ; (1 cycle)
000F 00              219                     NOP                                     ; Two "NOP" are necessary to get pr
                             ecisely 900 Hz (1 cycle each)
0010 22              220                     RET                                     ; return from subroutine (4 cycles)
                     221     
                     222     ;____________________________________________________________________
                     223     
                     224     END
