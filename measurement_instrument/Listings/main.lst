  78          void timer2(void) interrupt 5   // interrupt vector at 002BH
  79          {
  80   1        // Check what mode we are in:
  81   1        if ((SWITCHES&0x03) == 0x01) {
  82   2          // Frequency measurement mode. Increment the register, if it is 25, reset it and record the value on the
             - counter
  83   2          frequency_counter++;
  84   2          if (frequency_counter >= 25) {
  85   3            frequency_counter = 0;
  86   3            // Now record how many pulses T0 has counted in the last 0.125s. Can simply be bit shifted to get the f
             -requency in Hz.
  87   3            // Pass frequency through IIR filter to smooth it out
  88   3            frequency_value = TL0 + (TH0 << 8);
  89   3            frequency_value = ((7*frequency_value) >> 3) + (frequency_iir_output >> 3);
  90   3          }
  91   2        }
  92   1        TF2 = 0; // Clear the interrupt
  93   1        
  94   1      }  // end timer2 interrupt service routine
