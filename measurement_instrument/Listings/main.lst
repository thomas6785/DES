  87   1        // IIR Filter
  88   1        uint16 sample_value = ADCDATAL;
  89   1        sample_value = sample_value & 0x0FFF;
  90   1        adc_iir_output = ((7*sample_value) >> 3) + (adc_iir_output >> 3);
