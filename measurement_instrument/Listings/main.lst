  59          /*------------------------------------------------
  60          Interrupt service routine for timer 2 interrupt.
  61          Called by the hardware when the interrupt occurs.
  62          ------------------------------------------------*/
  63          void timer2(void) interrupt 5   // interrupt vector at 002BH
  64          {
  65   1        // Check what mode we are in:
  66   1        if ((SWITCHES&0x03) == 0x01) {
  67   2          // Frequency measurement mode. Increment the register, if it is 25, reset it and record the value on the
             - counter
  68   2          frequency_counter++;
  69   2          if (frequency_counter >= 25) {
  70   3            frequency_counter = 0;
  71   3            // Now record how many pulses T0 has counted in the last 0.125s. Can simply be bit shifted to get the f
             -requency in Hz.
  72   3            // Pass frequency through IIR filter to smooth it out
  73   3            frequency_value = TL0 + (TH0 << 8);
  74   3            frequency_value = ((7*frequency_value) >> 3) + (frequency_iir_output >> 3);
  75   3          }
  76   2        }
  77   1        TF2 = 0; // Clear the interrupt
  78   1        
  79   1      }  // end timer2 interrupt service routine
